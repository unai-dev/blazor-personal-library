@page "/authors"
@inject IAuthorService autorService

<MainHeader Header="Autores" SubHeader="Conoce algunos de nuestros autores mas famosos" />

<div class="my-4">
    <div class="row g-4 text-center">

        <GenericList List="@authors">
            <ChildContent>
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <AuthorListItem Author="context" @key="context.Id" />
                </div>
            </ChildContent>
        </GenericList>

    </div>
</div>


@code {
    private List<Author> authors = new List<Author>();

    protected override void OnInitialized()
    {
        authors = autorService.GetAuthors();
    }
}
