@page "/category/add"

@inject ICategoryService categoryService
@inject NavigationManager navigationManager

<MainHeader Header="Agregar Categoria" SubHeader="Agrega una nueva categoria" />

<CategoryForm Category="@category"
              CurrentPost="@currentPost"
              FormPostWithExit="@formPostWithExit"
              OnValidSumbit="@Add" />

@code {
    private Category category = null!;
    private EditContext? editContext;
    private bool invalidForm = true;
    private bool currentPost = false;
    private bool formPostWithExit = false;



    protected override void OnInitialized()
    {
        category = new Category();
    }

    private async Task Add()
    {
        if (!currentPost)
        {
            currentPost = true;
            Console.WriteLine($"Categoria agregada: {category.Name}");
            await Task.Delay(2000);

            currentPost = false;
            formPostWithExit = true;
            StateHasChanged();

            navigationManager.NavigateTo("/");
        }
    }

}
