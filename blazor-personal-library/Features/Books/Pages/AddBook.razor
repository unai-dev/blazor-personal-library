@page "/books/add"

@inject IBookService bookService
@inject NavigationManager navigationManager


<MainHeader Header="Agregar Libro" SubHeader="Agrega un nuevo libro a la libreria" />

<BookForm Book="@book"
          CurrentPost="@currentPost"
          PostWithExit="@formPostWithExit"
          OnValidSumbit="@AddNewBook" />

@code {
    private Book? book;
    private bool currentPost = false;
    private bool formPostWithExit = false;

    protected override void OnInitialized()
    {
        book = new Book();
    }

    private async Task AddNewBook()
    {
        if (!currentPost)
        {
            currentPost = true;

            bookService.AddNewBook(new Book
            {
                Author = book.Author,
                Title = book.Title,
                State = book.State
            });

            await Task.Delay(2000);

            currentPost = false;
            formPostWithExit = true;

            navigationManager.NavigateTo("/");

            StateHasChanged();
        }

    }


}
