
@if (Books != null)
{

    <ul>
        @foreach (var book in Books)
        {
            <BooksListItem @key="book.Id" Author="@book.Author" State="@book.State" Title="@book.Title" />
        }
    </ul>
    
} else
{
    <Loading/>
}




@code {
    [Parameter, EditorRequired] public List<Book>? Books { get; set; } = null;
}
