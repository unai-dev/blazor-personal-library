@inject IJSRuntime jSRuntime

@if (Books is null)
{
    <Loading>Loading books...</Loading>
}
else
{

    <div class="my-4">
        <div class="row g-4 text-center">

            <GenericList List="Books">
                <ChildContent>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <BooksListItem @key="context.Id" Book="context">
                            <BPButton Variant="Variant.Danger" Width="Width.Full" Size="Size.Sm" OnClick="@(() => RemoveBook(context))">Remove</BPButton>
                            <BPButton Variant="Variant.Success" Width="Width.Full" Size="Size.Sm">Edit</BPButton>
                        </BooksListItem>

                    </div>
                </ChildContent>
            </GenericList>

        </div>
    </div>
}





@code {
    [Parameter, EditorRequired] public List<Book>? Books { get; set; }

    private async Task RemoveBook(Book book)
    {
        string message = $"¿Desea eliminar el libro {book.Title}?";

        var confirm = await jSRuntime.Confirm(message);

        if (confirm)
        {
            Books!.Remove(book);
        }

    }

}
